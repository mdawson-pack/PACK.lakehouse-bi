ANTHROPIC_API_KEY=sk-ant-your-key-here

# Microsoft Fabric Lakehouse SQL endpoint
# FABRIC_SQL_ENDPOINT=your-workspace.datawarehouse.fabric.microsoft.com
# FABRIC_DATABASE=your_database_name
# FABRIC_CLIENT_ID=your-azure-app-client-id
# FABRIC_CLIENT_SECRET=your-azure-app-client-secret
# FABRIC_TENANT_ID=your-azure-tenant-id

# Set to "mock" to use mock data instead of a real Lakehouse connection
DATA_MODE=mock
